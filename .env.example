###> symfony/framework-bundle ###
APP_ENV=prod
APP_SECRET=change_me_to_a_random_32char_string
###< symfony/framework-bundle ###

###> steam ###
STEAM_API_KEY=your_steam_api_key
STEAM_ID=your_17digit_steam_id
###< steam ###

###> symfony/routing ###
DEFAULT_URI=https://steamgametracker.com
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://steamtracker:your_db_password@127.0.0.1:3306/steamtracker?serverVersion=8.0&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> docker ###
DB_PASSWORD=your_db_password
DB_ROOT_PASSWORD=your_db_root_password
###< docker ###

FRIEND_INVITE_TOKEN=your_secret_invite_token

###> symfony/mailer ###
MAILER_DSN=smtp://lukas%40steamgametracker.com:YOUR_ZOHO_PASSWORD@smtp.zoho.eu:587
MAILER_FROM=lukas@steamgametracker.com
###< symfony/mailer ###
