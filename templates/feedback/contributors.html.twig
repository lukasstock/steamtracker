{% extends 'base.html.twig' %}

{% block title %}Contributors · Steam Game Tracker{% endblock %}

{% block og_meta %}
<meta property="og:site_name"   content="Steam Game Tracker">
<meta property="og:type"        content="website">
<meta property="og:title"       content="Contributors · Steam Game Tracker">
<meta property="og:description" content="People who helped make Steam Game Tracker better with feedback and bug reports.">
<meta name="twitter:card"       content="summary">
<meta name="description"        content="People who helped make Steam Game Tracker better with feedback and bug reports.">
{% endblock %}

{% block body %}
<div class="min-h-screen" style="background:#1b2838;">

    <div class="border-b border-white/[0.06]" style="background:linear-gradient(135deg,rgba(26,159,255,0.06) 0%,rgba(164,208,7,0.04) 100%);">
        <div class="max-w-2xl mx-auto px-4 py-8">
            <a href="{{ path('feedback') }}"
               class="inline-flex items-center gap-2 text-steam-muted text-sm mb-4 hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" style="width:14px;height:14px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                Back to feedback
            </a>
            <h1 class="text-2xl font-black text-white">Contributors</h1>
            <p class="text-steam-muted text-sm mt-1">People who helped make this site better</p>
        </div>
    </div>

    <div class="max-w-2xl mx-auto px-4 py-10">

        <div class="rounded-2xl border border-white/[0.06] p-12 text-center" style="background:rgba(255,255,255,0.02);">
            <div style="font-size:2.5rem;line-height:1;margin-bottom:1rem;">🌱</div>
            <div class="text-white font-bold text-lg mb-2">No contributors yet</div>
            <p class="text-steam-muted text-sm mb-6">
                Be the first! Submit useful feedback or a bug report and you'll appear here.
            </p>
            <a href="{{ path('feedback') }}"
               class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold transition-colors"
               style="background:rgba(26,159,255,0.15);color:#1a9fff;border:1px solid rgba(26,159,255,0.3);">
                Give feedback
            </a>
        </div>

    </div>
</div>
{% endblock %}
