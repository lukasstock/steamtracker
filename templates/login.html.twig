{% extends 'base.html.twig' %}

{% block title %}Steam Game Tracker{% endblock %}

{% block head %}{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-sm">

        <div class="text-center mb-8">
            <h1 class="text-4xl font-black text-white tracking-tight">
                GAME
                <span style="background:linear-gradient(90deg,#1a9fff,#a4d007);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
                    LIBRARY
                </span>
            </h1>
            <p class="text-steam-muted text-sm mt-2">Owner access</p>
        </div>

        <div class="rounded-2xl border border-white/[0.08] p-7" style="background:#111923;">
            {% if error %}
            <div class="mb-4 px-4 py-2.5 rounded-lg text-sm text-red-400 border border-red-500/20" style="background:rgba(239,68,68,0.08);">
                {{ error }}
            </div>
            {% endif %}

            <form method="POST" action="/login">
                <label class="block text-xs uppercase tracking-widest text-steam-muted mb-2">Password</label>
                <input type="password" name="password" autofocus
                       class="w-full rounded-lg px-4 py-3 text-sm text-steam-light border border-white/10 outline-none focus:border-steam-blue transition-colors mb-5"
                       style="background:rgba(0,0,0,0.3);"
                       placeholder="Enter password">
                <button type="submit"
                        class="w-full py-3 rounded-lg text-sm font-bold text-white transition-opacity hover:opacity-90 active:scale-95"
                        style="background:#1a9fff;">
                    Login
                </button>
            </form>
        </div>

        <div class="text-center mt-5">
            <a href="/games" class="text-steam-muted text-sm hover:text-steam-light transition-colors">
                ← Back to library
            </a>
        </div>

    </div>
</div>
{% endblock %}
