{% extends 'base.html.twig' %}

{% block title %}{{ player.personaname is defined ? player.personaname ~ "'s" : 'Badges' }} Badges · Steam Game Tracker{% endblock %}

{% block head %}
<style>
@keyframes legendary-glow {
    0%   { box-shadow: 0 0 18px rgba(255,0,128,0.35), 0 0 40px rgba(255,0,128,0.08); border-color: rgba(255,0,128,0.55); }
    25%  { box-shadow: 0 0 18px rgba(255,165,0,0.35),  0 0 40px rgba(255,165,0,0.08);  border-color: rgba(255,165,0,0.55); }
    50%  { box-shadow: 0 0 18px rgba(0,200,255,0.35),  0 0 40px rgba(0,200,255,0.08);  border-color: rgba(0,200,255,0.55); }
    75%  { box-shadow: 0 0 18px rgba(160,0,255,0.35),  0 0 40px rgba(160,0,255,0.08);  border-color: rgba(160,0,255,0.55); }
    100% { box-shadow: 0 0 18px rgba(255,0,128,0.35),  0 0 40px rgba(255,0,128,0.08);  border-color: rgba(255,0,128,0.55); }
}
@keyframes legendary-bg {
    0%,100% { background-position: 0% 50%; }
    50%     { background-position: 100% 50%; }
}
@keyframes legendary-dot {
    0%   { background: #ff0080; box-shadow: 0 0 6px #ff0080; }
    25%  { background: #ff8c00; box-shadow: 0 0 6px #ff8c00; }
    50%  { background: #00c8ff; box-shadow: 0 0 6px #00c8ff; }
    75%  { background: #a000ff; box-shadow: 0 0 6px #a000ff; }
    100% { background: #ff0080; box-shadow: 0 0 6px #ff0080; }
}
.badge-legendary-card {
    animation: legendary-glow 3s ease-in-out infinite;
    background: linear-gradient(135deg,
        rgba(255,0,128,0.08) 0%,
        rgba(255,165,0,0.06) 25%,
        rgba(0,200,255,0.08) 60%,
        rgba(160,0,255,0.06) 100%
    ) !important;
    background-size: 200% 200%;
    animation: legendary-glow 3s ease-in-out infinite, legendary-bg 6s ease infinite;
}
.legendary-dot {
    animation: legendary-dot 3s ease-in-out infinite;
}
.legendary-label {
    background: linear-gradient(90deg, #ff0080, #ff8c00, #ffe600, #00c8ff, #a000ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: 700;
}
.legendary-label-bg {
    background: linear-gradient(90deg,
        rgba(255,0,128,0.12),
        rgba(255,165,0,0.12),
        rgba(0,200,255,0.12),
        rgba(160,0,255,0.12)
    );
}
</style>
{% endblock %}

{% block body %}
<div class="min-h-screen" style="background:#1b2838;">

    {# ── Hero header ── #}
    <div class="border-b border-white/[0.06]" style="background:linear-gradient(135deg,rgba(251,191,36,0.07) 0%,rgba(164,208,7,0.04) 100%);">
        <div class="max-w-6xl mx-auto px-4 py-8">
            <div class="flex items-center justify-between flex-wrap gap-4">
                <div class="flex items-center gap-4">
                    {% if player.avatarmedium is defined %}
                    <img src="{{ player.avatarmedium }}" alt="{{ player.personaname }}"
                         class="rounded-full flex-shrink-0"
                         style="width:48px;height:48px;border:2px solid rgba(251,191,36,0.3);">
                    {% endif %}
                    <div>
                        <h1 class="text-2xl font-black text-white leading-tight">
                            {% if player.personaname is defined %}{{ player.personaname }}'s {% endif %}Badges
                        </h1>
                        <p class="text-steam-muted text-sm mt-0.5">
                            <span class="font-bold" style="color:#fbbf24;">{{ earned_count }}</span>
                            / {{ total_count }} earned
                        </p>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <a href="{{ path('game_library', {steamId: steam_id}) }}"
                       class="text-xs text-steam-muted hover:text-white transition-colors">
                        ← Library
                    </a>
                </div>
            </div>

            {# Progress bar #}
            <div class="mt-5 max-w-sm">
                <div class="flex justify-between text-xs text-steam-muted mb-1.5">
                    <span>Progress</span>
                    <span>{{ earned_count }}/{{ total_count }}</span>
                </div>
                <div class="rounded-full overflow-hidden" style="height:6px;background:rgba(255,255,255,0.07);">
                    <div class="h-full rounded-full transition-all"
                         style="width:{{ total_count > 0 ? (earned_count / total_count * 100)|round : 0 }}%;background:linear-gradient(90deg,#fbbf24,#a4d007);"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="max-w-6xl mx-auto px-4 py-8">

        {# ── Category sections ── #}
        {% set categories = ['Completion', 'Playtime', 'Rating', 'Dropped', 'Library', 'Special'] %}
        {% for category in categories %}
        {% set cat_badges = badges|filter(b => b.category == category) %}
        {% if cat_badges|length > 0 %}

        <div class="mb-10">
            <h2 class="text-xs font-semibold uppercase tracking-widest mb-4" style="color:#8f98a0;">{{ category }}</h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">

            {% for badge in cat_badges %}
            {% set isLegendary = badge.tier == 'legendary' %}
            {% if badge.tier == 'bronze' %}
                {% set tierColor = '#cd7f32' %}
                {% set tierAlpha = 'rgba(205,127,50,0.15)' %}
                {% set tierLabel = 'Bronze' %}
            {% elseif badge.tier == 'silver' %}
                {% set tierColor = '#adb5bd' %}
                {% set tierAlpha = 'rgba(173,181,189,0.15)' %}
                {% set tierLabel = 'Silver' %}
            {% elseif badge.tier == 'gold' %}
                {% set tierColor = '#fbbf24' %}
                {% set tierAlpha = 'rgba(251,191,36,0.15)' %}
                {% set tierLabel = 'Gold' %}
            {% elseif badge.tier == 'platinum' %}
                {% set tierColor = '#e879f9' %}
                {% set tierAlpha = 'rgba(232,121,249,0.15)' %}
                {% set tierLabel = 'Platinum' %}
            {% else %}
                {# legendary - color vars used only for locked state / fallbacks #}
                {% set tierColor = '#ff0080' %}
                {% set tierAlpha = 'rgba(255,0,128,0.1)' %}
                {% set tierLabel = 'Legendary' %}
            {% endif %}

            <div class="relative rounded-2xl p-4 border transition-all flex flex-col gap-2.5 {% if badge.earned and isLegendary %}badge-legendary-card{% endif %}"
                 style="{% if badge.earned and not isLegendary %}background:{{ tierAlpha }};border-color:{{ tierColor }}33;box-shadow:0 0 20px {{ tierColor }}18;{% elseif not badge.earned %}background:rgba(255,255,255,0.02);border-color:rgba(255,255,255,0.06);opacity:0.55;{% endif %}">

                {# Lock overlay for unearned #}
                {% if not badge.earned %}
                <div class="absolute top-3 right-3">
                    <svg xmlns="http://www.w3.org/2000/svg" style="width:13px;height:13px;color:#8f98a0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="11" width="18" height="11" rx="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                </div>
                {% endif %}

                {# Tier dot (top-right, earned only) #}
                {% if badge.earned %}
                <div class="absolute top-3 right-3 w-2 h-2 rounded-full {% if isLegendary %}legendary-dot{% endif %}"
                     {% if not isLegendary %}style="background:{{ tierColor }};box-shadow:0 0 6px {{ tierColor }};"{% endif %}></div>
                {% endif %}

                {# Icon #}
                <div class="text-3xl leading-none select-none" style="{% if not badge.earned %}filter:grayscale(0.8);{% endif %}">
                    {{ badge.icon }}
                </div>

                {# Name + description #}
                <div>
                    <div class="text-sm font-bold leading-tight {% if badge.earned %}text-white{% else %}text-steam-muted{% endif %}">
                        {{ badge.name }}
                    </div>
                    <div class="text-xs text-steam-muted mt-0.5 leading-relaxed">
                        {{ badge.description }}
                    </div>
                </div>

                {# Tier label #}
                {% if isLegendary %}
                <div class="legendary-label-bg text-xs px-2 py-0.5 rounded-full self-start">
                    <span class="legendary-label">Legendary</span>
                </div>
                {% else %}
                <div class="text-xs font-semibold px-2 py-0.5 rounded-full self-start"
                     style="background:{{ tierAlpha }};color:{{ tierColor }};">
                    {{ tierLabel }}
                </div>
                {% endif %}

                {# Progress bar (only when not yet earned and goal > 1) #}
                {% if not badge.earned and badge.goal > 1 %}
                <div class="mt-auto pt-1">
                    <div class="flex justify-between text-xs text-steam-muted mb-1">
                        <span>{{ badge.progress|number_format(0, '.', ',') }}/{{ badge.goal|number_format(0, '.', ',') }}</span>
                        <span>{{ badge.goal > 0 ? (badge.progress / badge.goal * 100)|round : 0 }}%</span>
                    </div>
                    <div class="rounded-full overflow-hidden" style="height:3px;background:rgba(255,255,255,0.07);">
                        <div class="h-full rounded-full"
                             style="width:{{ badge.goal > 0 ? (badge.progress / badge.goal * 100)|round : 0 }}%;{% if isLegendary %}background:linear-gradient(90deg,#ff0080,#00c8ff,#a000ff);{% else %}background:{{ tierColor }};{% endif %}opacity:0.6;"></div>
                    </div>
                </div>
                {% endif %}

                {# Earned checkmark #}
                {% if badge.earned %}
                <div class="mt-auto pt-1 flex items-center gap-1 text-xs font-semibold"
                     {% if not isLegendary %}style="color:{{ tierColor }};"{% endif %}>
                    {% if isLegendary %}
                    <span class="legendary-label flex items-center gap-1">
                        <svg xmlns="http://www.w3.org/2000/svg" style="width:12px;height:12px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        Earned
                    </span>
                    {% else %}
                    <svg xmlns="http://www.w3.org/2000/svg" style="width:12px;height:12px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    Earned
                    {% endif %}
                </div>
                {% endif %}

            </div>
            {% endfor %}

            </div>
        </div>
        {% endif %}
        {% endfor %}

    </div>
</div>
{% endblock %}
