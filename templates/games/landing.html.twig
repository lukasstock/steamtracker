<section class="landing-section" style="position:relative;overflow:hidden;">

    <div class="orb" style="top:50%;left:50%;transform:translate(-50%,-50%);width:600px;height:300px;background:radial-gradient(ellipse,rgba(26,159,255,0.1),transparent 70%);"></div>

    <div class="landing-container" style="text-align:center;position:relative;">

        <img src="/images/trackerLogo.png" alt="" style="width:52px;height:52px;object-fit:contain;margin:0 auto 24px;display:block;">

        <h2 style="font-size:clamp(32px,4.5vw,52px);font-weight:900;color:#fff;letter-spacing:-0.025em;margin-bottom:16px;">
            Ready to take control?
        </h2>
        <p style="color:#8f98a0;font-size:16px;line-height:1.7;margin-bottom:40px;max-width:400px;margin-left:auto;margin-right:auto;">
            Sign in with your Steam account and your entire library is set up in seconds.
        </p>

        <div style="display:flex;flex-direction:column;align-items:center;gap:16px;">
            {% if logged_in_steam_id is defined and logged_in_steam_id %}
            <a href="{{ path('game_library', {steamId: logged_in_steam_id}) }}" class="btn-steam-signin" style="max-width:300px;background:rgba(26,159,255,0.15);border:1px solid rgba(26,159,255,0.3);box-shadow:none;">
                ← Back to my library
            </a>
            {% else %}
            <a href="{{ path('steam_auth') }}" class="btn-steam-signin" style="max-width:300px;">
                <svg xmlns="http://www.w3.org/2000/svg" style="width:20px;height:20px;flex-shrink:0;" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.188.006l2.861-4.142V8.91c0-2.495 2.028-4.524 4.524-4.524 2.494 0 4.524 2.031 4.524 4.527s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.727L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 11.999-5.373 11.999-12S18.605 0 11.979 0z"/>
                </svg>
                Sign in through Steam
            </a>

            <p style="margin:0;">
                <a href="{{ path('login') }}" style="color:#8f98a0;font-size:12px;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='#c6d4df'" onmouseout="this.style.color='#8f98a0'">Owner login</a>
            </p>
            {% endif %}
        </div>

    </div>
</section>

{% endblock %}
