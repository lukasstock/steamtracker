{% extends 'base.html.twig' %}

{% block title %}{{ player.personaname ?? 'Stats' }} · Stats · Steam Game Tracker{% endblock %}

{% block og_meta %}
{% set og_title = (player.personaname is defined ? player.personaname : 'A Gamer') ~ "'s Stats · Steam Game Tracker" %}
{% set og_pct   = total_games > 0 ? ((status_counts.completed / total_games) * 100)|round(1) : 0 %}
{% set og_desc  = status_counts.completed ~ ' completed · ' ~ og_pct ~ '% completion rate · ' ~ perfect_count ~ ' perfect games · ' ~ total_hours|number_format(0, '.', ',') ~ 'h played' %}
{% set og_image = app.request.schemeAndHttpHost ~ '/games/' ~ steam_id ~ '/og-image' %}
<meta property="og:site_name"    content="Steam Game Tracker">
<meta property="og:type"         content="website">
<meta property="og:url"          content="{{ app.request.uri }}">
<meta property="og:title"        content="{{ og_title }}">
<meta property="og:description"  content="{{ og_desc }}">
<meta property="og:image"        content="{{ og_image }}">
<meta property="og:image:width"  content="1200">
<meta property="og:image:height" content="630">
<meta name="twitter:card"        content="summary_large_image">
<meta name="twitter:title"       content="{{ og_title }}">
<meta name="twitter:description" content="{{ og_desc }}">
<meta name="twitter:image"       content="{{ og_image }}">
<meta name="description"         content="{{ og_desc }}">
{% endblock %}

{% block head %}
<style>
@keyframes legendary-glow {
    0%   { box-shadow: 0 0 8px rgba(255,0,128,0.35);  border-color: rgba(255,0,128,0.4); }
    25%  { box-shadow: 0 0 8px rgba(255,165,0,0.35);  border-color: rgba(255,165,0,0.4); }
    50%  { box-shadow: 0 0 8px rgba(0,200,255,0.35);  border-color: rgba(0,200,255,0.4); }
    75%  { box-shadow: 0 0 8px rgba(160,0,255,0.35);  border-color: rgba(160,0,255,0.4); }
    100% { box-shadow: 0 0 8px rgba(255,0,128,0.35);  border-color: rgba(255,0,128,0.4); }
}
</style>
{% endblock %}

{% block body %}
<div class="min-h-screen" style="background:#1b2838;">
<div class="max-w-5xl mx-auto px-4 py-10">

    {# Back link + Share #}
    <div class="flex items-center justify-between mb-8">
        <a href="{{ path('game_library', {steamId: steam_id}) }}"
           class="inline-flex items-center gap-2 text-steam-muted text-sm hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" style="width:14px;height:14px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
            Back to library
        </a>
        <div class="flex items-center gap-2">
            <a href="{{ path('game_badges', {steamId: steam_id}) }}"
               class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-xs font-semibold border transition-colors"
               style="background:rgba(255,255,255,0.04);border-color:rgba(255,255,255,0.1);color:#8f98a0;"
               onmouseover="this.style.background='rgba(255,255,255,0.08)'"
               onmouseout="this.style.background='rgba(255,255,255,0.04)'">
                <svg xmlns="http://www.w3.org/2000/svg" style="width:13px;height:13px;flex-shrink:0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/>
                </svg>
                Badges
            </a>
            <button onclick="copyStatsLink(this)"
                    class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-xs font-semibold border transition-colors"
                    style="background:rgba(255,255,255,0.04);border-color:rgba(255,255,255,0.1);color:#8f98a0;"
                    onmouseover="this.style.background='rgba(255,255,255,0.08)'"
                    onmouseout="this.style.background='rgba(255,255,255,0.04)'">
                <svg xmlns="http://www.w3.org/2000/svg" style="width:13px;height:13px;flex-shrink:0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/>
                </svg>
                Share
            </button>
        </div>
    </div>

    {# ── Hero header ── #}
    {% set completionPct = total_games > 0 ? ((status_counts.completed / total_games) * 100)|round(1) : 0 %}
    <div class="rounded-2xl p-8 mb-6 border border-white/[0.06] relative overflow-hidden"
         style="background:linear-gradient(135deg,rgba(26,159,255,0.08) 0%,rgba(164,208,7,0.06) 100%);">
        {# Decorative glow blobs #}
        <div class="absolute -top-16 -left-16 w-64 h-64 rounded-full pointer-events-none"
             style="background:radial-gradient(circle,rgba(26,159,255,0.12),transparent 70%);"></div>
        <div class="absolute -bottom-16 -right-16 w-64 h-64 rounded-full pointer-events-none"
             style="background:radial-gradient(circle,rgba(164,208,7,0.10),transparent 70%);"></div>

        <div class="relative flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
            {# Player info #}
            <div class="flex items-center gap-4">
                {% if player.avatarmedium is defined %}
                <img src="{{ player.avatarmedium }}" alt="" class="w-16 h-16 rounded-full ring-2 ring-white/10 flex-shrink-0">
                {% endif %}
                <div>
                    <div class="text-xs uppercase tracking-widest text-steam-muted mb-1">Library Stats</div>
                    <h1 class="text-3xl font-black text-white">{{ player.personaname ?? 'Stats' }}</h1>
                    <div class="text-steam-muted text-sm mt-1">{{ total_games }} games · {{ total_hours|number_format(0, '.', ',') }} hours played</div>
                </div>
            </div>

            {# Completion hero stat #}
            <div class="flex items-center gap-6 sm:gap-8">
                <div class="text-center">
                    <div class="text-5xl font-black leading-none" style="background:linear-gradient(135deg,#1a9fff,#a4d007);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
                        {{ completionPct }}%
                    </div>
                    <div class="text-xs text-steam-muted uppercase tracking-widest mt-2">Completion rate</div>
                </div>
                <div class="hidden sm:block w-px h-14 bg-white/10"></div>
                <div class="text-center hidden sm:block">
                    <div class="text-5xl font-black text-steam-green leading-none">{{ status_counts.completed }}</div>
                    <div class="text-xs text-steam-muted uppercase tracking-widest mt-2">Completed</div>
                </div>
            </div>
        </div>

        {# Stacked progress bar #}
        {% set statusDefs = [
            {key: 'completed', label: 'Completed', color: '#a4d007'},
            {key: 'playing',   label: 'Playing',   color: '#1a9fff'},
            {key: 'on_hold',   label: 'On Hold',   color: '#fbbf24'},
            {key: 'dropped',   label: 'Dropped',   color: '#f87171'},
            {key: 'unplayed',  label: 'Unplayed',  color: '#334155'},
        ] %}
        <div class="relative mt-6 rounded-full overflow-hidden flex" style="height:8px;background:rgba(255,255,255,0.04);">
            {% for s in statusDefs %}
            {% set pct = total_games > 0 ? ((status_counts[s.key] ?? 0) / total_games * 100)|round(1) : 0 %}
            {% if pct > 0 %}
            <div style="width:{{ pct }}%;background:{{ s.color }};" title="{{ s.label }}: {{ pct }}%"></div>
            {% endif %}
            {% endfor %}
        </div>
    </div>

    {# ── Badge strip ── #}
    {% if earned_badges|length > 0 %}
    <div class="flex items-center gap-2 mb-6 flex-wrap">
        {% for badge in earned_badges %}
        {% if badge.tier == 'bronze' %}{% set bc = '#cd7f32' %}{% set ba = 'rgba(205,127,50,0.12)' %}
        {% elseif badge.tier == 'silver' %}{% set bc = '#adb5bd' %}{% set ba = 'rgba(173,181,189,0.12)' %}
        {% elseif badge.tier == 'gold' %}{% set bc = '#fbbf24' %}{% set ba = 'rgba(251,191,36,0.12)' %}
        {% elseif badge.tier == 'platinum' %}{% set bc = '#e879f9' %}{% set ba = 'rgba(232,121,249,0.12)' %}
        {% else %}{% set bc = '#ff0080' %}{% set ba = 'rgba(255,0,128,0.1)' %}
        {% endif %}
        <div class="group relative flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold border cursor-default select-none"
             style="background:{{ ba }};border-color:{{ bc }}44;{% if badge.tier == 'legendary' %}animation:legendary-glow 3s ease-in-out infinite;{% else %}box-shadow:0 0 8px {{ bc }}18;{% endif %}">
            <span>{{ badge.icon }}</span>
            <span style="color:{% if badge.tier == 'legendary' %}#ff88cc{% else %}{{ bc }}{% endif %};">{{ badge.name }}</span>
            <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1.5 hidden group-hover:block z-10 whitespace-nowrap">
                <div class="text-xs text-white px-2 py-1 rounded-lg border border-white/10"
                     style="background:rgba(15,20,30,0.95);">{{ badge.description }}</div>
            </div>
        </div>
        {% endfor %}
        <a href="{{ path('game_badges', {steamId: steam_id}) }}"
           class="ml-1 text-xs text-steam-muted hover:text-white transition-colors whitespace-nowrap">
            {{ earned_badge_count }}/{{ total_badge_count }} badges →
        </a>
    </div>
    {% endif %}

    {# ── Stat tiles ── #}
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
        <div class="rounded-xl p-5 border border-white/[0.06] relative overflow-hidden group hover:border-white/20 transition-colors cursor-default"
             style="background:rgba(255,255,255,0.02);">
            <div class="absolute top-0 left-0 right-0 h-px" style="background:linear-gradient(90deg,transparent,rgba(26,159,255,0.5),transparent);"></div>
            <div class="text-3xl font-black text-white">{{ status_counts.playing }}</div>
            <div class="text-xs text-steam-muted uppercase tracking-widest mt-1">Playing</div>
        </div>
        <div class="rounded-xl p-5 border border-white/[0.06] relative overflow-hidden group hover:border-white/20 transition-colors cursor-default"
             style="background:rgba(255,255,255,0.02);">
            <div class="absolute top-0 left-0 right-0 h-px" style="background:linear-gradient(90deg,transparent,rgba(248,113,113,0.5),transparent);"></div>
            <div class="text-3xl font-black text-red-400">{{ status_counts.dropped }}</div>
            <div class="text-xs text-steam-muted uppercase tracking-widest mt-1">Dropped</div>
        </div>
        <div class="rounded-xl p-5 border border-white/[0.06] relative overflow-hidden group hover:border-white/20 transition-colors cursor-default"
             style="background:rgba(255,255,255,0.02);">
            <div class="absolute top-0 left-0 right-0 h-px" style="background:linear-gradient(90deg,transparent,rgba(251,191,36,0.6),transparent);"></div>
            <div class="text-3xl font-black" style="color:#fbbf24;">{{ perfect_count }}</div>
            <div class="text-xs text-steam-muted uppercase tracking-widest mt-1">Perfect Games</div>
        </div>
        <div class="rounded-xl p-5 border border-white/[0.06] relative overflow-hidden group hover:border-white/20 transition-colors cursor-default"
             style="background:rgba(255,255,255,0.02);">
            <div class="absolute top-0 left-0 right-0 h-px" style="background:linear-gradient(90deg,transparent,rgba(251,191,36,0.4),transparent);"></div>
            {% if avg_rating %}
            <div class="text-3xl font-black text-white">{{ avg_rating }}</div>
            <div class="text-xs mt-0.5" style="color:#fbbf24;">
                {%- for i in 1..5 -%}<span style="opacity:{{ i <= avg_rating|round ? '1' : '0.25' }};">★</span>{%- endfor -%}
            </div>
            {% else %}
            <div class="text-3xl font-black text-steam-muted">—</div>
            {% endif %}
            <div class="text-xs text-steam-muted uppercase tracking-widest mt-1">Avg Rating</div>
        </div>
    </div>

    {# ── Favourites ── #}
    {% if favourites|length > 0 %}
    <div class="rounded-2xl p-6 border border-white/[0.06] mb-6" style="background:rgba(255,255,255,0.02);">
        <div class="flex items-center justify-between gap-3 mb-4">
            <div class="flex items-baseline gap-3">
                <h2 class="text-sm font-semibold text-white uppercase tracking-widest">Favourites</h2>
                <span class="text-steam-muted text-xs">{{ favourites|length }} game{{ favourites|length != 1 ? 's' : '' }}</span>
            </div>
            {% if is_owner %}
            <span class="text-xs text-steam-muted">
                {% if favourites_manual %}
                    Showing your spotlighted games · <a href="{{ path('game_library', {steamId: steam_id}) }}" class="text-steam-blue hover:text-white transition-colors">Edit in library</a>
                {% else %}
                    Auto-selected · <a href="{{ path('game_library', {steamId: steam_id}) }}" class="text-steam-blue hover:text-white transition-colors">Spotlight games to customise</a>
                {% endif %}
            </span>
            {% endif %}
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            {% for game in favourites %}
            <div class="group flex flex-col gap-2">
                <div class="rounded-xl overflow-hidden relative" style="aspect-ratio:460/215;">
                    <img src="https://cdn.cloudflare.steamstatic.com/steam/apps/{{ game.appid }}/header.jpg"
                         alt="{{ game.name }}"
                         class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                         onerror="this.parentElement.style.background='rgba(255,255,255,0.05)'">
                    {% if game.rating == 5 %}
                    <div class="absolute top-1.5 right-1.5 text-xs font-bold px-1.5 py-0.5 rounded"
                         style="background:rgba(251,191,36,0.9);color:#1b2838;">★ 5</div>
                    {% endif %}
                </div>
                <div class="text-xs font-semibold text-steam-light truncate group-hover:text-white transition-colors" title="{{ game.name }}">{{ game.name }}</div>
                {% if game.rating %}
                <div class="text-xs" style="color:#fbbf24;letter-spacing:1px;">
                    {%- for i in 1..5 -%}<span style="opacity:{{ i <= game.rating ? '1' : '0.2' }};">★</span>{%- endfor -%}
                </div>
                {% endif %}
            </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    {# ── Status breakdown + Rating + Insights ── #}
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">

        {# Status breakdown #}
        <div class="rounded-2xl p-6 border border-white/[0.06]" style="background:rgba(255,255,255,0.02);">
            <h2 class="text-sm font-semibold text-white uppercase tracking-widest mb-5">Status Breakdown</h2>
            <div class="flex flex-col gap-4">
                {% for s in statusDefs %}
                {% set count = status_counts[s.key] ?? 0 %}
                {% set pct   = total_games > 0 ? ((count / total_games) * 100)|round(1) : 0 %}
                <div>
                    <div class="flex justify-between text-xs mb-1.5">
                        <span class="font-medium" style="color:{{ s.color }};">{{ s.label }}</span>
                        <span class="text-steam-muted">
                            <span class="text-steam-light font-semibold">{{ count }}</span>
                            <span class="opacity-50 ml-1">{{ pct }}%</span>
                        </span>
                    </div>
                    <div class="rounded-full overflow-hidden" style="height:6px;background:rgba(255,255,255,0.05);">
                        <div class="h-full rounded-full" style="width:{{ pct }}%;background:{{ s.color }};box-shadow:0 0 8px {{ s.color }}40;"></div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>

        {# Rating distribution + Insights #}
        <div class="rounded-2xl p-6 border border-white/[0.06]" style="background:rgba(255,255,255,0.02);">
            <h2 class="text-sm font-semibold text-white uppercase tracking-widest mb-1">Ratings</h2>
            {% if rated_count > 0 %}
            <p class="text-xs text-steam-muted mb-5">{{ rated_count }} rated game{{ rated_count != 1 ? 's' : '' }}</p>
            {% set maxRatingCount = max_rating_count %}
            <div class="flex flex-col gap-3">
                {% for star in [5,4,3,2,1] %}
                {% set count = ratings[star] ?? 0 %}
                {% set pct   = maxRatingCount > 0 ? (count / maxRatingCount * 100)|round : 0 %}
                <div class="flex items-center gap-3">
                    <div class="text-xs flex-shrink-0" style="width:48px;color:#fbbf24;letter-spacing:1px;">
                        {%- for i in 1..5 -%}<span style="opacity:{{ i <= star ? '1' : '0.2' }};">★</span>{%- endfor -%}
                    </div>
                    <div class="flex-1 rounded-full overflow-hidden" style="height:6px;background:rgba(255,255,255,0.05);">
                        <div class="h-full rounded-full" style="width:{{ pct }}%;background:#fbbf24;box-shadow:0 0 6px rgba(251,191,36,0.4);"></div>
                    </div>
                    <div class="text-xs text-steam-muted flex-shrink-0 text-right" style="width:24px;">{{ count }}</div>
                </div>
                {% endfor %}
            </div>
            {% else %}
            <div class="flex items-center justify-center h-24 text-steam-muted text-sm">No rated games yet.</div>
            {% endif %}

            {# Playtime insights #}
            {% if avg_playtime_completed or avg_playtime_dropped or most_played_unfinished %}
            <div class="mt-5 pt-5 border-t border-white/[0.06] grid grid-cols-1 gap-3">
                {% if avg_playtime_completed %}
                <div class="flex justify-between items-center">
                    <span class="text-xs text-steam-muted">Avg hours to complete</span>
                    <span class="text-sm font-bold text-steam-green">{{ avg_playtime_completed }}h</span>
                </div>
                {% endif %}
                {% if avg_playtime_dropped %}
                <div class="flex justify-between items-center">
                    <span class="text-xs text-steam-muted">Avg hours before dropping</span>
                    <span class="text-sm font-bold text-red-400">{{ avg_playtime_dropped }}h</span>
                </div>
                {% endif %}
                {% if most_played_unfinished %}
                <div class="flex justify-between items-center gap-4">
                    <span class="text-xs text-steam-muted flex-shrink-0">Most played unfinished</span>
                    <span class="text-xs font-semibold text-steam-light truncate text-right" title="{{ most_played_unfinished.name }}">
                        {{ most_played_unfinished.name }}
                        <span class="text-steam-muted font-normal ml-1">{{ most_played_unfinished.hours }}h</span>
                    </span>
                </div>
                {% endif %}
            </div>
            {% endif %}
        </div>

    </div>

    {# ── Most Played ── #}
    {% if top_played|length > 0 %}
    <div class="rounded-2xl p-6 border border-white/[0.06] mb-6" style="background:rgba(255,255,255,0.02);">
        <h2 class="text-sm font-semibold text-white uppercase tracking-widest mb-5">Most Played</h2>
        {% set maxHours = top_played[0].hours %}
        {% set statusColors = {
            'completed': '#a4d007',
            'playing':   '#1a9fff',
            'dropped':   '#f87171',
            'on_hold':   '#fbbf24',
            'unplayed':  '#334155',
        } %}
        <div class="flex flex-col gap-4">
            {% for game in top_played %}
            {% set barPct = maxHours > 0 ? (game.hours / maxHours * 100)|round : 0 %}
            {% set col    = statusColors[game.status] %}
            <div class="flex items-center gap-4">
                <img src="https://cdn.cloudflare.steamstatic.com/steam/apps/{{ game.appid }}/header.jpg"
                     alt=""
                     class="rounded flex-shrink-0"
                     style="width:56px;height:26px;object-fit:cover;"
                     onerror="this.style.display='none'">
                <div class="flex-1 min-w-0">
                    <div class="flex justify-between text-xs mb-1.5">
                        <span class="text-steam-light font-medium truncate" style="max-width:280px;" title="{{ game.name }}">{{ game.name }}</span>
                        <span class="text-steam-muted flex-shrink-0 ml-3">{{ game.hours }}h</span>
                    </div>
                    <div class="rounded-full overflow-hidden" style="height:5px;background:rgba(255,255,255,0.05);">
                        <div class="h-full rounded-full" style="width:{{ barPct }}%;background:{{ col }};box-shadow:0 0 6px {{ col }}50;"></div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    {# ── Backlog ── #}
    {% if backlog_games > 0 %}
    <div class="rounded-2xl px-6 py-5 border border-white/[0.06] flex items-center justify-between gap-6"
         style="background:rgba(255,255,255,0.02);">
        <div>
            <div class="text-sm font-semibold text-white mb-1">Unplayed Backlog</div>
            <p class="text-steam-muted text-xs leading-relaxed">
                {{ backlog_games }} game{{ backlog_games != 1 ? 's' : '' }} you own but haven't started.
                {% if backlog_hours > 0 %}
                At your average pace, that's roughly
                <span class="text-steam-light font-semibold">{{ backlog_hours|number_format(0, '.', ',') }} hours</span>
                of content
                <span class="opacity-60">({{ backlog_with_hltb }} of {{ backlog_games }} matched HLTB data).</span>
                {% endif %}
            </p>
        </div>
        <div class="flex-shrink-0 text-right">
            <div class="text-4xl font-black text-steam-muted">{{ backlog_games }}</div>
            <div class="text-xs text-steam-muted uppercase tracking-widest mt-0.5">games</div>
        </div>
    </div>
    {% endif %}

</div>
</div>

<script>
function copyStatsLink(btn) {
    navigator.clipboard.writeText(window.location.href).then(() => {
        const orig = btn.innerHTML;
        btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" style="width:13px;height:13px;flex-shrink:0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Copied!';
        btn.style.color = '#a4d007';
        btn.style.borderColor = 'rgba(164,208,7,0.4)';
        setTimeout(() => { btn.innerHTML = orig; btn.style.color = ''; btn.style.borderColor = ''; }, 2000);
    });
}
</script>
{% endblock %}
