<script>
const STEAM_ID  = '{{ steam_id }}';
const IS_OWNER  = {{ is_owner ? 'true' : 'false' }};
function copyLibraryLink(btn) {
    let url = window.location.href.split('?')[0]; // strip existing params
    if (url.includes('ngrok')) url += '?ngrok-skip-browser-warning=true';
    navigator.clipboard.writeText(url).then(() => {
        const orig = btn.innerHTML;
        btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" style="width:13px;height:13px;flex-shrink:0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Copied!';
        btn.style.color = '#a4d007';
        btn.style.borderColor = 'rgba(164,208,7,0.4)';
        setTimeout(() => { btn.innerHTML = orig; btn.style.color = ''; btn.style.borderColor = ''; }, 2000);
    });
}
</script>
