{% if is_owner %}
<script>
// ── Spotlight drag & drop ──────────────────────────────────────────────────

const _dnd = {
    steamId:  '{{ steam_id }}',
    appId:    null,
    source:   null,   // 'library' | 'spotlight'
    srcCard:  null,
};

function _dndInit() {
    document.querySelectorAll('.game-card').forEach(_bindLibraryCard);
    document.querySelectorAll('.spotlight-card').forEach(_bindSpotlightCard);
    _setupDropZones();
}

function _bindLibraryCard(card) {
    card.setAttribute('draggable', 'true');
    card.addEventListener('dragstart', e => {
        if (card.dataset.spotlight === '1') { e.preventDefault(); return; }
        _dnd.appId   = card.dataset.appid;
        _dnd.source  = 'library';
        _dnd.srcCard = card;
        e.dataTransfer.effectAllowed = 'move';
        requestAnimationFrame(() => card.style.opacity = '0.45');
        document.getElementById('spotlight-grid')?.classList.add('dnd-spotlight-target');
        const empty = document.getElementById('spotlight-empty');
        if (empty) empty.classList.add('dnd-spotlight-target');
    });
    card.addEventListener('dragend', _dndEnd);
}

function _bindSpotlightCard(card) {
    card.setAttribute('draggable', 'true');
    card.addEventListener('dragstart', e => {
        _dnd.appId   = card.dataset.appid;
        _dnd.source  = 'spotlight';
        _dnd.srcCard = card;
        e.dataTransfer.effectAllowed = 'move';
        requestAnimationFrame(() => card.style.opacity = '0.4');
        document.getElementById('spotlight-remove-zone')?.classList.remove('hidden');
    });
    card.addEventListener('dragend', _dndEnd);
}

function _dndEnd(e) {
    if (_dnd.srcCard) _dnd.srcCard.style.opacity = '';
    document.getElementById('spotlight-grid')?.classList.remove('dnd-spotlight-target', 'dnd-over');
    document.getElementById('spotlight-empty')?.classList.remove('dnd-spotlight-target', 'dnd-over');
    document.getElementById('spotlight-remove-zone')?.classList.add('hidden');
    document.getElementById('spotlight-remove-zone')?.classList.remove('dnd-remove-over');
    _dnd.appId = _dnd.source = _dnd.srcCard = null;
}

function _setupDropZones() {
    // ── Spotlight grid + empty state → add to spotlight ──────────────────
    ['spotlight-grid', 'spotlight-empty'].forEach(id => {
        const el = document.getElementById(id);
        if (!el) return;
        el.addEventListener('dragover', e => {
            if (_dnd.source !== 'library') return;
            e.preventDefault();
            el.classList.add('dnd-over');
        });
        el.addEventListener('dragleave', () => el.classList.remove('dnd-over'));
        el.addEventListener('drop', e => {
            e.preventDefault();
            el.classList.remove('dnd-over');
            if (_dnd.source === 'library' && _dnd.appId) _doUpdate(_dnd.appId, true);
        });
    });

    // ── Remove zone → remove from spotlight ───────────────────────────────
    const removeZone = document.getElementById('spotlight-remove-zone');
    if (removeZone) {
        removeZone.addEventListener('dragover', e => {
            if (_dnd.source !== 'spotlight') return;
            e.preventDefault();
            removeZone.classList.add('dnd-remove-over');
        });
        removeZone.addEventListener('dragleave', () => removeZone.classList.remove('dnd-remove-over'));
        removeZone.addEventListener('drop', e => {
            e.preventDefault();
            removeZone.classList.remove('dnd-remove-over');
            if (_dnd.source === 'spotlight' && _dnd.appId) _doUpdate(_dnd.appId, false);
        });
    }
}

async function _doUpdate(appId, spotlight) {
    const lib = document.querySelector(`.game-card[data-appid="${appId}"]`);

    const body = {
        spotlight,
        status:   lib?.dataset.status   || 'unplayed',
        rating:   parseInt(lib?.dataset.rating) || 0,
        notes:    lib?.dataset.notes    || '',
        app_name: lib?.dataset.appName  || '',
    };

    try {
        const res = await fetch(`/games/${_dnd.steamId}/${appId}/update`, {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify(body),
        });
        if (!res.ok) throw new Error('HTTP ' + res.status);
    } catch (err) {
        console.error('Spotlight DnD update failed', err);
        return;
    }

    if (lib) lib.dataset.spotlight = spotlight ? '1' : '0';

    if (spotlight) {
        _insertSpotlightCard(appId, lib);
    } else {
        _removeSpotlightCard(appId);
    }
}

function _insertSpotlightCard(appId, lib) {
    const grid = document.getElementById('spotlight-grid');
    if (!grid || grid.querySelector(`[data-appid="${appId}"]`)) return;

    const name   = lib?.dataset.appName || lib?.querySelector('a')?.textContent?.trim() || '';
    const rating = parseInt(lib?.dataset.rating) || 0;
    const notes  = lib?.dataset.notes || '';
    const status = lib?.dataset.status || 'unplayed';

    const stars = rating > 0
        ? Array.from({length: 5}, (_, i) =>
            `<span style="opacity:${i < rating ? 1 : 0.3}">★</span>`).join('')
        : '';

    const card = document.createElement('div');
    card.className = 'spotlight-card group relative rounded-xl overflow-hidden cursor-pointer';
    card.dataset.appid   = appId;
    card.dataset.status  = status;
    card.dataset.rating  = rating;
    card.dataset.notes   = notes;
    card.dataset.spotlight = '1';
    card.dataset.appName = name;
    card.innerHTML = `
        <img src="https://cdn.cloudflare.steamstatic.com/steam/apps/${appId}/header.jpg"
             alt="${name}" class="w-full block"
             onerror="this.parentElement.style.background='#111923'">
        <div class="absolute inset-0 pointer-events-none"
             style="background:linear-gradient(to bottom,transparent 25%,rgba(0,0,0,0.95) 100%)"></div>
        <div class="absolute bottom-0 left-0 right-0 px-4 pb-4 pt-8">
            <div class="text-white font-bold text-sm leading-tight mb-1">${name}</div>
            ${stars ? `<div class="text-yellow-400 text-xs tracking-tighter mb-1.5">${stars}</div>` : ''}
            ${notes ? `<div class="text-steam-muted text-xs leading-snug line-clamp-2">${notes}</div>` : ''}
        </div>
        <div class="absolute inset-0 flex items-center justify-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none group-hover:pointer-events-auto"
             style="background:rgba(0,0,0,0.65);">
            <button onclick="openModal(${appId}, this); event.stopPropagation();"
                    class="px-3 py-2 rounded-lg text-sm font-bold border border-white/20 text-white hover:bg-white/10 transition-colors active:scale-95">
                ✏ Edit
            </button>
            <a href="/games/${_dnd.steamId}/${appId}"
               class="px-3 py-2 rounded-lg text-sm font-bold border border-white/20 text-white hover:bg-white/10 transition-colors"
               onclick="event.stopPropagation()">
                Details →
            </a>
        </div>`;

    _bindSpotlightCard(card);

    document.getElementById('spotlight-empty')?.classList.add('hidden');
    grid.appendChild(card);
}

function _removeSpotlightCard(appId) {
    document.querySelector(`.spotlight-card[data-appid="${appId}"]`)?.remove();

    const grid  = document.getElementById('spotlight-grid');
    const empty = document.getElementById('spotlight-empty');
    if (grid && empty && grid.querySelectorAll('.spotlight-card').length === 0) {
        empty.classList.remove('hidden');
    }
}

// CSS for drag-over states (injected once, avoids extra stylesheet)
const _dndStyle = document.createElement('style');
_dndStyle.textContent = `
    #spotlight-grid.dnd-spotlight-target,
    #spotlight-empty.dnd-spotlight-target {
        outline: 2px dashed rgba(251,191,36,0.35);
        outline-offset: 6px;
        border-radius: 12px;
        transition: outline-color 0.15s;
    }
    #spotlight-grid.dnd-over,
    #spotlight-empty.dnd-over {
        outline-color: rgba(251,191,36,0.8);
        background: rgba(251,191,36,0.04);
    }
    #spotlight-remove-zone.dnd-remove-over {
        background: rgba(248,113,113,0.1) !important;
        border-color: rgba(248,113,113,0.55) !important;
        color: #f87171 !important;
    }
`;
document.head.appendChild(_dndStyle);

document.addEventListener('DOMContentLoaded', _dndInit);
</script>
{% endif %}
{% endblock %}
