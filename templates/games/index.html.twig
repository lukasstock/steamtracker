{% extends 'base.html.twig' %}

{% block title %}{{ (player.personaname is defined ? player.personaname : 'A Gamer') ~ "'s Steam Library · Steam Game Tracker" }}{% endblock %}

{% block og_meta %}
{% set og_title = (player.personaname is defined ? player.personaname : 'A Gamer') ~ "'s Steam Library · Steam Game Tracker" %}
{% set og_desc  = (steam_id == '76561198088051125' ? 'Top 0.3% of Steam users · ' : '') ~ counts.completed ~ ' completed · ' ~ counts.playing ~ ' playing · ' ~ total ~ ' games tracked' %}
{% set og_image = app.request.schemeAndHttpHost ~ '/games/' ~ steam_id ~ '/og-image' %}
<meta property="og:site_name"    content="Steam Game Tracker">
<meta property="og:type"         content="website">
<meta property="og:url"          content="{{ app.request.uri }}">
<meta property="og:title"        content="{{ og_title }}">
<meta property="og:description"  content="{{ og_desc }}">
<meta property="og:image"        content="{{ og_image }}">
<meta property="og:image:width"  content="1200">
<meta property="og:image:height" content="630">
<meta name="twitter:card"        content="summary_large_image">
<meta name="twitter:title"       content="{{ og_title }}">
<meta name="twitter:description" content="{{ og_desc }}">
<meta name="twitter:image"       content="{{ og_image }}">
<meta name="description"         content="{{ og_desc }}">
{% endblock %}

{% block jsonld %}
{% if player.personaname is defined %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "name": "{{ player.personaname }}'s Steam Library",
  "url": "{{ app.request.uri }}",
  "mainEntity": {
    "@type": "Person",
    "name": "{{ player.personaname }}",
    "image": "{{ player.avatarfull ?? player.avatarmedium ?? '' }}"
  }
}
</script>
{% endif %}
{% endblock %}

{% block head %}
<link rel="stylesheet" href="/css/games.css">
<style>
@keyframes legendary-glow {
    0%   { box-shadow: 0 0 8px rgba(255,0,128,0.35);  border-color: rgba(255,0,128,0.4); }
    25%  { box-shadow: 0 0 8px rgba(255,165,0,0.35);  border-color: rgba(255,165,0,0.4); }
    50%  { box-shadow: 0 0 8px rgba(0,200,255,0.35);  border-color: rgba(0,200,255,0.4); }
    75%  { box-shadow: 0 0 8px rgba(160,0,255,0.35);  border-color: rgba(160,0,255,0.4); }
    100% { box-shadow: 0 0 8px rgba(255,0,128,0.35);  border-color: rgba(255,0,128,0.4); }
}
</style>
{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 py-10">

    {# ── Header ── #}
    <div class="flex items-start justify-between mb-10">
        <div>
            {% if player.avatarmedium is defined %}
            <div class="flex items-center gap-3 mb-3">
                <img src="{{ player.avatarmedium }}"
                     alt="{{ player.personaname }}"
                     class="rounded-full flex-shrink-0"
                     style="width:40px;height:40px;border:2px solid rgba(255,255,255,0.1);">
                <span class="text-white font-semibold text-sm">{{ player.personaname }}</span>
            </div>
            {% endif %}
            <h1 class="text-5xl font-black tracking-tight text-white leading-none">
                GAME
                <span style="background:linear-gradient(90deg,#1a9fff,#a4d007);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
                    LIBRARY
                </span>
            </h1>
            <p class="text-steam-muted text-sm mt-2">Track your completion progress</p>
        </div>
        <div class="flex items-center gap-2 mt-1" style="white-space:nowrap;">
            <a href="{{ path('activity_feed') }}"
               class="flex items-center gap-2 px-4 py-2 rounded-lg text-xs font-semibold border transition-colors"
               style="background:rgba(255,255,255,0.04);border-color:rgba(255,255,255,0.1);color:#8f98a0;"
               onmouseover="this.style.background='rgba(255,255,255,0.08)'"
               onmouseout="this.style.background='rgba(255,255,255,0.04)'">
                <svg xmlns="http://www.w3.org/2000/svg" style="width:13px;height:13px;flex-shrink:0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
                </svg>
                Feed
            </a>
            <a href="{{ path('leaderboard') }}"
               class="flex items-center gap-2 px-4 py-2 rounded-lg text-xs font-semibold border transition-colors"
               style="background:rgba(255,255,255,0.04);border-color:rgba(255,255,255,0.1);color:#8f98a0;"
               onmouseover="this.style.background='rgba(255,255,255,0.08)'"
               onmouseout="this.style.background='rgba(255,255,255,0.04)'">
                <svg xmlns="http://www.w3.org/2000/svg" style="width:13px;height:13px;flex-shrink:0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>
                </svg>
                Leaderboard
            </a>
            <a href="{{ path('game_stats', {steamId: steam_id}) }}"
               class="flex items-center gap-2 px-4 py-2 rounded-lg text-xs font-semibold border transition-colors"
               style="background:rgba(255,255,255,0.04);border-color:rgba(255,255,255,0.1);color:#8f98a0;"
               onmouseover="this.style.background='rgba(255,255,255,0.08)'"
               onmouseout="this.style.background='rgba(255,255,255,0.04)'">
                <svg xmlns="http://www.w3.org/2000/svg" style="width:13px;height:13px;flex-shrink:0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>
                </svg>
                Stats
            </a>
            <a href="{{ path('game_badges', {steamId: steam_id}) }}"
               class="flex items-center gap-2 px-4 py-2 rounded-lg text-xs font-semibold border transition-colors"
               style="background:rgba(255,255,255,0.04);border-color:rgba(255,255,255,0.1);color:#8f98a0;"
               onmouseover="this.style.background='rgba(255,255,255,0.08)'"
               onmouseout="this.style.background='rgba(255,255,255,0.04)'">
                <svg xmlns="http://www.w3.org/2000/svg" style="width:13px;height:13px;flex-shrink:0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/>
                </svg>
                Badges
            </a>
            <a href="{{ path('game_compare_pick', {steamId: steam_id}) }}"
               class="flex items-center gap-2 px-4 py-2 rounded-lg text-xs font-semibold border transition-colors"
               style="background:rgba(255,255,255,0.04);border-color:rgba(255,255,255,0.1);color:#8f98a0;"
               onmouseover="this.style.background='rgba(255,255,255,0.08)'"
               onmouseout="this.style.background='rgba(255,255,255,0.04)'">
                <svg xmlns="http://www.w3.org/2000/svg" style="width:13px;height:13px;flex-shrink:0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                Compare with friends
            </a>
            <button id="share-btn"
                    onclick="copyLibraryLink(this)"
                    class="flex items-center gap-2 px-4 py-2 rounded-lg text-xs font-semibold border transition-colors"
                    style="background:rgba(255,255,255,0.04);border-color:rgba(255,255,255,0.1);color:#8f98a0;"
                    onmouseover="this.style.background='rgba(255,255,255,0.08)'"
                    onmouseout="this.style.background='rgba(255,255,255,0.04)'">
                <svg xmlns="http://www.w3.org/2000/svg" style="width:13px;height:13px;flex-shrink:0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/>
                </svg>
                Share
            </button>
            {% if is_owner %}
            <button id="ach-sync-btn"
                    onclick="startAchievementSync()"
                    class="flex items-center gap-2 px-4 py-2 rounded-lg text-xs font-semibold border transition-colors"
                    style="background:rgba(255,255,255,0.04);border-color:rgba(255,255,255,0.1);color:#8f98a0;"
                    onmouseover="this.style.background='rgba(255,255,255,0.08)'"
                    onmouseout="this.style.background='rgba(255,255,255,0.04)'">
                🏆 Sync Achievements
            </button>
            <a href="/logout"
               class="flex items-center gap-2 px-4 py-2 rounded-lg text-xs font-semibold border transition-colors"
               style="background:rgba(239,68,68,0.08);border-color:rgba(239,68,68,0.25);color:#f87171;"
               onmouseover="this.style.background='rgba(239,68,68,0.18)'"
               onmouseout="this.style.background='rgba(239,68,68,0.08)'">
                <svg xmlns="http://www.w3.org/2000/svg" style="width:13px;height:13px;flex-shrink:0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
                Sign out
            </a>
            {% endif %}
        </div>
    </div>

    {# ── Now Playing ── #}
    {% if now_playing %}
    <div class="flex items-center gap-4 px-5 py-3.5 rounded-xl border mb-6"
         style="background:rgba(26,159,255,0.06); border-color:rgba(26,159,255,0.2);">
        <img src="https://cdn.cloudflare.steamstatic.com/steam/apps/{{ now_playing.appid }}/header.jpg"
             alt="{{ now_playing.name }}"
             class="rounded-lg flex-shrink-0 object-cover"
             style="width:94px; height:44px;"
             onerror="this.style.display='none'">
        <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 text-xs text-steam-muted uppercase tracking-widest mb-0.5">
                <span class="w-1.5 h-1.5 rounded-full bg-steam-green inline-block animate-pulse"></span>
                Now Playing
            </div>
            <div class="text-white font-bold truncate">{{ now_playing.name }}</div>
        </div>
    </div>
    {% endif %}

    {# ── First-login import banner ── #}
    {% if imported > 0 %}
    <div class="rounded-xl px-5 py-4 mb-6 border text-sm flex items-start gap-3"
         style="background:rgba(26,159,255,0.07);border-color:rgba(26,159,255,0.2);">
        <span class="text-xl leading-none mt-0.5">🎮</span>
        <div>
            <span class="font-semibold text-white">Welcome to Steam Game Tracker!</span>
            <span class="text-steam-light"> We imported <strong>{{ imported }}</strong> games you've played.
            {% if auto_completed > 0 %}
                <strong>{{ auto_completed }}</strong> were marked <strong>Completed</strong> based on your playtime matching HowLongToBeat data,
                and <strong>{{ imported - auto_completed }}</strong> were marked <strong>Playing</strong>.
            {% else %}
                All were marked <strong>Playing</strong> - correct any you've finished, or hit <strong>Sync Achievements</strong> to auto-complete games you've 100%'d.
            {% endif %}
            </span>
        </div>
    </div>
    {% endif %}

    {# ── Stats ── #}
    {% set pct = counts.completed > 0 ? ((counts.completed / total) * 100)|round(1) : 0 %}
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 mb-4">
        <div class="rounded-xl p-5 border border-white/[0.06] relative overflow-hidden" style="background:rgba(164,208,7,0.07);">
            <div class="absolute top-0 left-4 right-4 h-px" style="background:linear-gradient(90deg,transparent,rgba(164,208,7,0.6),transparent)"></div>
            <div class="text-4xl font-black text-steam-green" id="stat-completed">{{ counts.completed }}</div>
            <div class="text-steam-muted text-xs uppercase tracking-widest mt-1.5">Completed</div>
        </div>
        <div class="rounded-xl p-5 border border-white/[0.06] relative overflow-hidden" style="background:rgba(26,159,255,0.07);">
            <div class="absolute top-0 left-4 right-4 h-px" style="background:linear-gradient(90deg,transparent,rgba(26,159,255,0.6),transparent)"></div>
            <div class="text-4xl font-black text-steam-blue" id="stat-playing">{{ counts.playing }}</div>
            <div class="text-steam-muted text-xs uppercase tracking-widest mt-1.5">Playing</div>
        </div>
        <div class="rounded-xl p-5 border border-white/[0.06] relative overflow-hidden" style="background:rgba(255,255,255,0.04);">
            <div class="absolute top-0 left-4 right-4 h-px" style="background:linear-gradient(90deg,transparent,rgba(255,255,255,0.2),transparent)"></div>
            <div class="text-4xl font-black text-white" id="stat-backlog">{{ counts.unplayed + counts.on_hold }}</div>
            <div class="text-steam-muted text-xs uppercase tracking-widest mt-1.5">Backlog</div>
        </div>
        <div class="rounded-xl p-5 border border-white/[0.06] relative overflow-hidden" style="background:rgba(255,255,255,0.03);">
            <div class="absolute top-0 left-4 right-4 h-px" style="background:linear-gradient(90deg,transparent,rgba(255,255,255,0.15),transparent)"></div>
            <div class="text-4xl font-black text-steam-muted" id="stat-total">{{ total }}</div>
            <div class="text-steam-muted text-xs uppercase tracking-widest mt-1.5">Total</div>
        </div>
        <div class="rounded-xl p-5 border border-white/[0.06] relative overflow-hidden" style="background:rgba(255,255,255,0.03);">
            <div class="absolute top-0 left-4 right-4 h-px" style="background:linear-gradient(90deg,transparent,rgba(255,255,255,0.15),transparent)"></div>
            <div class="text-4xl font-black text-steam-muted">{{ total_hours|number_format(0) }}<span class="text-2xl font-bold">h</span></div>
            <div class="text-steam-muted text-xs uppercase tracking-widest mt-1.5">Playtime</div>
        </div>
        <div class="rounded-xl p-5 border border-white/[0.06] relative overflow-hidden" style="background:rgba(251,191,36,0.07);">
            <div class="absolute top-0 left-4 right-4 h-px" style="background:linear-gradient(90deg,transparent,rgba(251,191,36,0.5),transparent)"></div>
            <div class="text-4xl font-black" style="color:#fbbf24;" id="stat-perfect">{{ perfect_count }}</div>
            <div class="text-steam-muted text-xs uppercase tracking-widest mt-1.5">Perfect Games</div>
        </div>
    </div>

    {# Progress bar #}
    <div class="rounded-xl px-5 py-4 mb-8 border border-white/[0.06]" style="background:rgba(255,255,255,0.04);">
        <div class="flex justify-between text-xs mb-2.5">
            <span class="text-steam-muted font-medium">Completion Progress</span>
            <span class="text-white font-bold" id="stat-pct">{{ pct }}%</span>
        </div>
        <div class="w-full rounded-full h-2.5 overflow-hidden" style="background:rgba(0,0,0,0.4);">
            <div id="progress-bar" class="h-2.5 rounded-full transition-all duration-700" style="width:{{ pct }}%"></div>
        </div>
    </div>

    {# ── Badge strip ── #}
    {% if top_badges|length > 0 %}
    <div class="flex items-center gap-2 mb-8 flex-wrap">
        {% for badge in top_badges %}
        {% if badge.tier == 'bronze' %}{% set bc = '#cd7f32' %}{% set ba = 'rgba(205,127,50,0.12)' %}
        {% elseif badge.tier == 'silver' %}{% set bc = '#adb5bd' %}{% set ba = 'rgba(173,181,189,0.12)' %}
        {% elseif badge.tier == 'gold' %}{% set bc = '#fbbf24' %}{% set ba = 'rgba(251,191,36,0.12)' %}
        {% elseif badge.tier == 'platinum' %}{% set bc = '#e879f9' %}{% set ba = 'rgba(232,121,249,0.12)' %}
        {% else %}{% set bc = '#ff0080' %}{% set ba = 'rgba(255,0,128,0.1)' %}
        {% endif %}
        <div class="group relative flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold border cursor-default select-none"
             style="background:{{ ba }};border-color:{{ bc }}44;{% if badge.tier == 'legendary' %}animation:legendary-glow 3s ease-in-out infinite;{% else %}box-shadow:0 0 8px {{ bc }}18;{% endif %}">
            <span style="{% if badge.tier == 'legendary' %}filter:none;{% endif %}">{{ badge.icon }}</span>
            <span style="color:{% if badge.tier == 'legendary' %}#ff88cc{% else %}{{ bc }}{% endif %};">{{ badge.name }}</span>
            {# Tooltip #}
            <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1.5 hidden group-hover:block z-10 whitespace-nowrap">
                <div class="text-xs text-white px-2 py-1 rounded-lg border border-white/10"
                     style="background:rgba(15,20,30,0.95);">{{ badge.description }}</div>
            </div>
        </div>
        {% endfor %}
        <a href="{{ path('game_badges', {steamId: steam_id}) }}"
           class="ml-1 text-xs text-steam-muted hover:text-white transition-colors whitespace-nowrap">
            {{ earned_badge_count }}/{{ total_badge_count }} badges →
        </a>
    </div>
    {% endif %}

    {# ── Spotlight ── #}
    {% set spotlight_games = games|filter(g => g.is_spotlight) %}
    {% if spotlight_games|length > 0 or is_owner %}
    <div id="spotlight-section" class="mb-10">
        <div class="flex items-center gap-3 mb-5">
            <span class="text-xs uppercase tracking-widest font-bold" style="color:#fbbf24;letter-spacing:0.12em;">♦ Spotlight</span>
            <div class="flex-1 h-px" style="background:linear-gradient(90deg,rgba(251,191,36,0.35),transparent)"></div>
        </div>
        <div id="spotlight-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {% for game in spotlight_games %}
            <div class="spotlight-card group relative rounded-xl overflow-hidden cursor-pointer"
                 data-appid="{{ game.appid }}"
                 data-status="{{ game.status }}"
                 data-rating="{{ game.rating ?? 0 }}"
                 data-notes="{{ game.notes|e('html_attr') }}"
                 data-spotlight="1"
                 data-notes-public="{{ game.notes_public ? '1' : '0' }}"
                 data-app-name="{{ game.name|e('html_attr') }}">
                <img src="https://cdn.cloudflare.steamstatic.com/steam/apps/{{ game.appid }}/header.jpg"
                     alt="{{ game.name }}"
                     class="w-full block"
                     onerror="handleImageError(this, {{ game.appid }})">
                <div class="absolute inset-0 pointer-events-none"
                     style="background:linear-gradient(to bottom, transparent 25%, rgba(0,0,0,0.95) 100%)"></div>
                <div class="absolute bottom-0 left-0 right-0 px-4 pb-4 pt-8">
                    <div class="text-white font-bold text-sm leading-tight mb-1">{{ game.name }}</div>
                    {% if game.rating %}
                    <div class="text-yellow-400 text-xs tracking-tighter mb-1.5">
                        {%- for i in 1..5 -%}{{ i <= game.rating ? '★' : '☆' }}{%- endfor -%}
                    </div>
                    {% endif %}
                    {% if game.notes and (game.notes_public or is_owner) %}
                    <div class="text-steam-muted text-xs leading-snug line-clamp-2">{{ game.notes }}</div>
                    {% endif %}
                </div>
                {# Hover overlay with Edit + Details #}
                <div class="absolute inset-0 flex items-center justify-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none group-hover:pointer-events-auto"
                     style="background:rgba(0,0,0,0.65);">
                    {% if is_owner %}
                    <button onclick="openModal({{ game.appid }}, this); event.stopPropagation();"
                            class="px-3 py-2 rounded-lg text-sm font-bold border border-white/20 text-white hover:bg-white/10 transition-colors active:scale-95">
                        ✏ Edit
                    </button>
                    {% endif %}
                    <a href="{{ path('game_detail', {steamId: steam_id, appId: game.appid}) }}"
                       class="px-3 py-2 rounded-lg text-sm font-bold border border-white/20 text-white hover:bg-white/10 transition-colors"
                       onclick="event.stopPropagation()">
                        Details →
                    </a>
                </div>
            </div>
            {% endfor %}
        </div>
        {% if spotlight_games|length == 0 and is_owner %}
        <div id="spotlight-empty" class="rounded-xl border border-dashed py-10 text-center text-sm"
             style="border-color:rgba(251,191,36,0.2);background:rgba(251,191,36,0.03);color:#8f98a0;">
            Edit any game and tap <span style="color:#fbbf24;">♦ Add to Spotlight</span> to feature it here
        </div>
        {% endif %}
    </div>
    {% endif %}

    {# ── Spotlight remove zone (appears only while dragging a spotlight card) ── #}
    {% if is_owner %}
    <div id="spotlight-remove-zone"
         class="hidden mb-6 rounded-xl border border-dashed py-4 text-center text-xs font-semibold transition-colors select-none"
         style="border-color:rgba(248,113,113,0.25);background:rgba(248,113,113,0.04);color:rgba(248,113,113,0.6);">
        ✕ Drop here to remove from Spotlight
    </div>
    {% endif %}

    {# ── Controls ── #}
    <div class="flex flex-col sm:flex-row gap-3 mb-8">
        <div class="flex flex-wrap gap-2">
            <button onclick="setFilter('all')" id="filter-all"
                class="filter-btn px-4 py-2 rounded-lg text-sm font-semibold bg-steam-blue text-white">
                All <span id="count-all" class="ml-1 opacity-60">{{ total }}</span>
            </button>
            <button onclick="setFilter('playing')" id="filter-playing"
                class="filter-btn px-4 py-2 rounded-lg text-sm font-semibold text-steam-light border border-white/10 hover:bg-steam-blue hover:border-steam-blue hover:text-white"
                style="background:rgba(255,255,255,0.05);">
                Playing <span id="count-playing" class="ml-1 opacity-60">{{ counts.playing }}</span>
            </button>
            <button onclick="setFilter('completed')" id="filter-completed"
                class="filter-btn px-4 py-2 rounded-lg text-sm font-semibold text-steam-light border border-white/10 hover:bg-steam-blue hover:border-steam-blue hover:text-white"
