    setInterval(updateClock, 1000);
    updateClock();

    // Fake live stats that keep changing
    const gameCount = document.getElementById('game-count');
    const hoursCount = document.getElementById('hours-count');
    const lifeCount = document.getElementById('life-count');
    const regretCount = document.getElementById('regret-count');

    function randomInt(min, max) {
        return Math.floor(Math.random() * (max - min + 1)) + min;
    }

    function updateStats() {
        gameCount.textContent = randomInt(420, 9999);
        hoursCount.textContent = randomInt(10000, 99999).toLocaleString();
        lifeCount.textContent = randomInt(60, 99) + '%';
        regretCount.textContent = ['MAX', '∞', 'YES', '💀', 'A LOT'][Math.floor(Math.random() * 5)];
    }
    setInterval(updateStats, 800);
    updateStats();

    // Game roulette
    const games = [
        'Horse Game 2004', 'Dark Souls (good luck)', 'Half-Life 3 (lol)',
        'Euro Truck Simulator', 'FIFA 2003', 'Minesweeper',
        'Goat Simulator', 'Farming Simulator', 'Just go outside',
        'Nothing. Stare at the wall.', 'Your backlog (all 847 games)',
        'The one you\'ve been meaning to finish for 6 years',
    ];
    document.getElementById('roulette-btn').addEventListener('click', function() {
        const result = games[Math.floor(Math.random() * games.length)];
        document.getElementById('roulette-result').textContent = result;
    });

    // Shoutbox fake messages
