    // Cursor trail
    document.addEventListener('mousemove', (e) => {
        if (Math.random() > 0.85) {
            const star = document.createElement('div');
            star.textContent = ['✨','💀','🎮','⭐','🔥'][Math.floor(Math.random()*5)];
            star.style.cssText = `position:fixed;left:${e.clientX}px;top:${e.clientY}px;pointer-events:none;z-index:9998;font-size:20px;animation:float-up 1.5s linear forwards;`;
            document.body.appendChild(star);
            setTimeout(() => star.remove(), 1500);
        }
    });
</script>
