        '<GamingLegend99> lol',
        '<anonymous> send help',
        '<webmaster_tom> no',
    ];
    let shoutIndex = 0;
    const shoutbox = document.getElementById('shoutbox-msgs');
    setInterval(() => {
        const msg = document.createElement('div');
        msg.textContent = shoutMessages[shoutIndex % shoutMessages.length];
        shoutbox.appendChild(msg);
        shoutbox.scrollTop = shoutbox.scrollHeight;
        shoutIndex++;
